<% content_for :title do %>
  <%= t("request_form.#{@form.name}.#{@information_request.subject}") %>
<% end %>

<%= f.govuk_fieldset legend: { text: t("helpers.legend.request_form.form_request_subject_name"), tag: "h1" } do %>
  <%= f.govuk_text_field :full_name, label: { size: "s" } %>
  <%= f.govuk_text_field :other_names, label: { size: "s", text: t("helpers.label.request_form.other_names.#{@information_request.subject}") } %>
<% end %>
